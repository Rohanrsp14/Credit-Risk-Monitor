# Virtual environment
venv/

# Raw data (large, redistributable from source)
data/raw/*.csv

# Processed data (large, regenerable via src/ loaders)
data/processed/*.csv

# Secrets
.env

# Python
__pycache__/
*.pyc

# Model artifacts
models/*.pkl

# Generated outputs — small artifacts (csv/html) are committed so
# Streamlit Cloud has real data to read; anything else (e.g. future
# large exports) stays ignored by default.
outputs/*
!outputs/*.csv
!outputs/*.html
